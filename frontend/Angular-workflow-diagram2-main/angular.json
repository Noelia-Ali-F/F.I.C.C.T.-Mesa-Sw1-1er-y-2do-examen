{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "workflow-frontend-angular": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css",
              "node_modules/diagram-js/assets/diagram-js.css",
              "node_modules/bpmn-js/dist/assets/bpmn-js.css",
              "node_modules/bpmn-js/dist/assets/bpmn-font/css/bpmn-embedded.css",
              "node_modules/diagram-js-minimap/assets/diagram-js-minimap.css",
              "node_modules/@foblex/flow/styles/default.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "30kB",
                  "maximumError": "60kB"
                }
              ],
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json",
              "styles": [
                "src/styles.css",
                "node_modules/diagram-js/assets/diagram-js.css",
                "node_modules/bpmn-js/dist/assets/bpmn-js.css",
                "node_modules/bpmn-js/dist/assets/bpmn-font/css/bpmn-embedded.css",
                "node_modules/diagram-js-minimap/assets/diagram-js-minimap.css",
                "node_modules/@foblex/flow/styles/default.scss"
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "styles": [
                "src/styles.css",
                "node_modules/diagram-js/assets/diagram-js.css",
                "node_modules/bpmn-js/dist/assets/bpmn-js.css",
                "node_modules/bpmn-js/dist/assets/bpmn-font/css/bpmn-embedded.css",
                "node_modules/diagram-js-minimap/assets/diagram-js-minimap.css",
                "node_modules/@foblex/flow/styles/default.scss"
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "workflow-frontend-angular:build:production"
            },
            "development": {
              "buildTarget": "workflow-frontend-angular:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "styles": [
              "src/styles.css",
              "node_modules/diagram-js/assets/diagram-js.css",
              "node_modules/bpmn-js/dist/assets/bpmn-js.css",
              "node_modules/bpmn-js/dist/assets/bpmn-font/css/bpmn-embedded.css",
              "node_modules/diagram-js-minimap/assets/diagram-js-minimap.css",
              "node_modules/@foblex/flow/styles/default.scss"
            ]
          }
        }
      }
    }
  }
}
